# ── Config I/O ────────────────────────────────────────────────────────────────
def read_config():
    cp = configparser.ConfigParser()
    if os.path.exists(CONFIG):
        try:
            cp.read(CONFIG)
        except Exception:
            pass

    def get(k, d):
        try:
            return cp.get("Colors", k).strip()
        except Exception:
            return d

    scheme = get("scheme", "dark")

    # Use active preset as defaults so all palette colors are always set correctly
    preset_name = get("preset", "Bloom")
    preset      = PRESETS.get(preset_name, PRESETS["Bloom"])
    preset_var  = preset.get(scheme, preset.get("dark", {}))
    defs        = preset_var if preset_var else (DARK_DEFAULTS if scheme == "dark" else LIGHT_DEFAULTS)

    return {
        "accent":   get("accent",   defs.get("accent",   "#B01828")),
        "bg":       get("bg",       defs.get("bg",       DARK_DEFAULTS["bg"])),
        "surface":  get("surface",  defs.get("surface",  DARK_DEFAULTS["surface"])),
        "overlay":  get("overlay",  defs.get("overlay",  DARK_DEFAULTS["overlay"])),
        "text":     get("text",     defs.get("text",     DARK_DEFAULTS["text"])),
        "text_dim": get("text_dim", defs.get("text_dim", DARK_DEFAULTS["text_dim"])),
        "scheme":   scheme,
        "font":     get("font",     "JetBrainsMono Nerd Font 11"),
    }


def write_config(colors):
    os.makedirs(os.path.dirname(CONFIG), exist_ok=True)
    lines = [
        "[Colors]",
        "# Bloom color scheme — managed by Bloom Settings",
        "",
        f"accent   = {colors['accent']}",
        f"bg       = {colors['bg']}",
        f"surface  = {colors['surface']}",
        f"overlay  = {colors['overlay']}",
        f"text     = {colors['text']}",
        f"text_dim = {colors['text_dim']}",
        f"scheme   = {colors['scheme']}",
        f"font     = {colors.get('font', 'JetBrainsMono Nerd Font 11')}",
        "",
    ]
    open(CONFIG, "w").write("\n".join(lines))


# ── Color math helpers ────────────────────────────────────────────────────────
def hex_to_rgb(h):
    h = h.lstrip("#")
    if len(h) == 3:
        h = "".join(c*2 for c in h)
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))


def rgba(h, a):
    r, g, b = hex_to_rgb(h)
    return f"rgba({r}, {g}, {b}, {a:.2f})"


# ── Generate files ────────────────────────────────────────────────────────────
def generate(c):
    acc = c["accent"]
    bg  = c["bg"]
    sur = c["surface"]
    ovr = c["overlay"]
    txt = c["text"]
    dim = c["text_dim"]

    # ── EWW SCSS (in-place replacement of the tokens block) ─────────────────────
    # NOTE: markers use ASCII only — eww's grass SCSS compiler adds @charset "UTF-8"
    # for any non-ASCII chars in the CSS output, which GTK CSS parser rejects.
    eww_conf_dir = os.path.dirname(EWW_SCSS)
    eww_main_scss = os.path.join(eww_conf_dir, "eww.scss")
    # If the user config doesn't exist yet, copy from the system template
    if not os.path.exists(eww_main_scss):
        template = "/etc/xdg/eww/eww.scss"
        if os.path.exists(template):
            import shutil
            os.makedirs(eww_conf_dir, exist_ok=True)
            shutil.copy2(template, eww_main_scss)
    if os.path.exists(eww_main_scss):
        try:
            content = open(eww_main_scss).read()
            tokens = (
                "/* Color tokens - regenerated by bloom-generate-colors */\n"
                f"$accent:        {acc};\n"
                f"$accent-15:     {rgba(acc, 0.15)};\n"
                f"$accent-25:     {rgba(acc, 0.25)};\n"
                f"$accent-40:     {rgba(acc, 0.40)};\n"
                f"$accent-45:     {rgba(acc, 0.45)};\n"
                f"$accent-70:     {rgba(acc, 0.70)};\n"
                f"$accent-80:     {rgba(acc, 0.80)};\n"
                f"$accent-32:     {rgba(acc, 0.32)};\n"
                f"$accent-55:     {rgba(acc, 0.55)};\n"
                f"$accent-22:     {rgba(acc, 0.22)};\n"
                f"$bg:            {bg};\n"
                f"$text:          {txt};\n"
                f"$text-dim:      {dim};\n"
                f"$text-faint:    {dim};\n"
                f"$surface:       {rgba(bg, 0.75)};\n"
                f"$border:        rgba(255, 255, 255, 0.15);\n"
                f"$shadow:        {rgba('#000000', 0.37)};\n"
                "/* -- End color tokens ------------------------------------------------------ */"
            )
            # Replace the block between the ASCII markers
            # Use flexible pattern to match any length of dashes in the end marker
            new_content = re.sub(
                r"/\* Color tokens - regenerated by bloom-generate-colors \*/"
                r".*?"
                r"/\* -- End color tokens[\s\-]+\*/",
                tokens, content, flags=re.DOTALL
            )
            open(eww_main_scss, "w").write(new_content)
        except Exception as e:
            print(f"Error updating eww.scss: {e}")

    # ── Waybar GTK @define-color ──────────────────────────────────────────────
    os.makedirs(os.path.dirname(WB_CSS), exist_ok=True)
    wb_css = f"""/* Bloom waybar color tokens — generated by bloom-generate-colors */
@define-color bloom_accent      {acc};
@define-color bloom_accent_15   {rgba(acc, 0.15)};
@define-color bloom_accent_20   {rgba(acc, 0.20)};
@define-color bloom_accent_70   {rgba(acc, 0.70)};
@define-color bloom_text        {txt};
@define-color bloom_text_dim    {dim};
@define-color bloom_surface     {rgba(bg, 0.75)};
@define-color bloom_border      rgba(255, 255, 255, 0.15);
"""
    open(WB_CSS, "w").write(wb_css)

    # ── Waybar Island Style (in-place replacement) ───────────────────────────
    isl_style = "/etc/xdg/waybar/island-style.css"
    if os.path.exists(isl_style):
        try:
            content = open(isl_style).read()
            new_style = re.sub(
                r"background:.*?;", f"background: {rgba(bg, 0.72)};", content
            )
            new_style = re.sub(
                r"border:.*?;", f"border: 1px solid rgba(255, 255, 255, 0.15);", new_style
            )
            new_style = re.sub(
                r"box-shadow:.*?;", f"box-shadow: 0 8px 32px 0 {rgba('#000000', 0.37)};", new_style
            )
            open(isl_style, "w").write(new_style)
        except Exception:
            pass

    # ── Shared CSS custom properties ──────────────────────────────────────────
    os.makedirs(os.path.dirname(OUT_CSS), exist_ok=True)
    css = f"""/* Generated by bloom-generate-colors */
:root {{
  --bloom-accent:     {acc};
  --bloom-accent-15:  {rgba(acc, 0.15)};
  --bloom-accent-40:  {rgba(acc, 0.40)};
  --bloom-accent-70:  {rgba(acc, 0.70)};
  --bloom-bg:         {bg};
  --bloom-surface:    {sur};
  --bloom-overlay:    {ovr};
  --bloom-text:       {txt};
  --bloom-text-dim:   {dim};
  --bloom-border:     rgba(255,255,255,0.07);
  --bloom-shadow:     rgba(0,0,0,0.72);
}}
"""
    open(OUT_CSS, "w").write(css)

    # ── Shell vars ────────────────────────────────────────────────────────────
    sh = f"""# Generated by bloom-generate-colors — source this file
BLOOM_ACCENT="{acc}"
BLOOM_BG="{bg}"
BLOOM_SURFACE="{sur}"
BLOOM_TEXT="{txt}"
BLOOM_TEXT_DIM="{dim}"
BLOOM_SCHEME="{c['scheme']}"
"""
    open(OUT_SH, "w").write(sh)

    # ── Rofi colours (imported by bloom.rasi / bloom-fullscreen.rasi) ────────
    # The two bloom rofi themes start with `@import "bloom-colors"` so rofi
    # picks up palette changes live without re-baking the whole theme file.
    rofi_dir = os.path.join(HOME, ".config/rofi")
    os.makedirs(rofi_dir, exist_ok=True)
    rofi_colors_path = os.path.join(rofi_dir, "bloom-colors.rasi")
    open(rofi_colors_path, "w").write(f"""\
/* Auto-generated by bloom-generate-colors. DO NOT edit by hand —
   change the palette in Bloom Settings → Appearance instead. */
* {{
    bg:          {rgba(bg, 0.95)};
    bg-alt:      {rgba(sur, 0.90)};
    bg-sel:      {rgba(acc, 0.33)};
    fg:          {txt};
    fg-dim:      {dim};
    accent:      {acc};
    border-col:  {rgba(acc, 0.22)};
}}
""")

    # ── GTK4 CSS (picked up automatically by all GTK4 apps) ──────────────────
    gtk4_css_dir = os.path.join(HOME, ".config/gtk-4.0")
    os.makedirs(gtk4_css_dir, exist_ok=True)
    gtk4_css_path = os.path.join(gtk4_css_dir, "gtk.css")
    # Only write the bloom block; preserve any user-added rules
    bloom_block = f"""
/* bloom-colors-start */
@define-color accent_color {acc};
@define-color accent_bg_color {rgba(acc, 0.25)};
@define-color window_bg_color {bg};
@define-color window_fg_color {txt};
@define-color view_bg_color {sur};
@define-color view_fg_color {txt};
/* bloom-colors-end */
"""
    existing = ""
    try:
        existing = open(gtk4_css_path).read()
    except Exception:
        pass
    # Strip old bloom block
    existing = re.sub(r"/\* bloom-colors-start \*/.*?/\* bloom-colors-end \*/\n?",
                      "", existing, flags=re.DOTALL)
    open(gtk4_css_path, "w").write(bloom_block + existing)

    print(f"bloom-generate-colors: accent={acc} scheme={c['scheme']}")


# ── Reload desktop ────────────────────────────────────────────────────────────
def reload_desktop(c):
    # Waybar: SIGUSR2 reloads CSS hot
    subprocess.run(["pkill", "-SIGUSR2", "waybar"], capture_output=True)

    # EWW: reload SCSS via daemon restart
    config_dir = os.path.join(HOME, ".config/eww")
    if os.path.exists(config_dir):
        subprocess.run(["pkill", "-f", "notif-daemon.sh"], capture_output=True)
        subprocess.run(["eww", "--config", config_dir, "kill"], capture_output=True)
        import time; time.sleep(0.3)
        subprocess.Popen(["bloom-island"])

    # GTK color-scheme preference (dark/light)
    scheme_val = "prefer-dark" if c["scheme"] == "dark" else "prefer-light"
    subprocess.run(["gsettings", "set", "org.gnome.desktop.interface",
                    "color-scheme", scheme_val], capture_output=True)

    # GTK font
    font = c.get("font", "").strip()
    if font:
        subprocess.run(["gsettings", "set", "org.gnome.desktop.interface",
                        "font-name", font], capture_output=True)


if __name__ == "__main__":
    no_reload = "--no-reload" in sys.argv
    colors = read_config()
    generate(colors)
    if not no_reload:
        reload_desktop(colors)
