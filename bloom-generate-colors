#!/usr/bin/env python3
"""
bloom-generate-colors — regenerate all color tokens from ~/.config/bloom/colors.conf
Writes:
  /etc/xdg/eww/colors.scss              (imported by eww.scss)
  ~/.config/waybar/colors.css           (imported by waybar/style.css)
  ~/.local/share/bloom/colors.css       (CSS custom properties, for future use)
  ~/.local/share/bloom/colors.sh        (shell-sourceable vars)
Then hot-reloads waybar (SIGUSR2) and restarts bloom-island (eww).

Usage:
  bloom-generate-colors             # regenerate and reload
  bloom-generate-colors --no-reload # generate files only
"""
