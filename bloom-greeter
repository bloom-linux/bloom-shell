#!/usr/bin/env python3
"""bloom-greeter — Bloom Linux graphical greeter for greetd (runs under cage)."""

import gi
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib

import os, json, socket, struct, threading, time, pwd, subprocess

# ── greetd IPC ───────────────────────────────────────────────────────────────

_sock = None

def _greetd_connect():
    global _sock
    path = os.environ.get("GREETD_SOCK", "/run/greetd.sock")
    _sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    _sock.connect(path)

def _greetd_send(msg):
    payload = json.dumps(msg).encode()
    _sock.sendall(struct.pack("!I", len(payload)) + payload)

def _greetd_recv():
    raw = b""
    while len(raw) < 4:
        raw += _sock.recv(4 - len(raw))
    length = struct.unpack("!I", raw)[0]
    data = b""
    while len(data) < length:
        data += _sock.recv(length - len(data))
    return json.loads(data)

def greetd(msg):
    _greetd_send(msg)
    return _greetd_recv()

# ── Discovery ─────────────────────────────────────────────────────────────────

def get_sessions():
    sessions = []
    for d in ["/usr/share/wayland-sessions", "/usr/share/xsessions"]:
        if not os.path.isdir(d):
            continue
        for f in sorted(os.listdir(d)):
            if not f.endswith(".desktop"):
                continue
            name, exec_cmd = f.replace(".desktop", ""), None
            try:
                with open(os.path.join(d, f)) as fh:
                    for line in fh:
                        if line.startswith("Name="):
                            name = line.split("=", 1)[1].strip()
                        if line.startswith("Exec="):
                            exec_cmd = line.split("=", 1)[1].strip()
            except Exception:
                pass
            if exec_cmd:
                sessions.append((name, exec_cmd))
    return sessions or [("Hyprland", "uwsm start hyprland.desktop")]

def get_users():
    try:
        users = [p.pw_name for p in pwd.getpwall()
                 if 1000 <= p.pw_uid < 60000 and os.path.isdir(p.pw_dir)]
    except Exception:
        users = []
    return users or ["liveuser"]

