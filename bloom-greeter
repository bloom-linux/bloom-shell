# ── App ───────────────────────────────────────────────────────────────────────

class BloomGreeter(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="bloom.greeter")
        self._username = None
        self._session_cmds = []

    def do_activate(self):
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        win = Gtk.ApplicationWindow(application=self)
        win.set_decorated(False)
        win.fullscreen()
        self._win = win

        overlay = Gtk.Overlay()
        win.set_child(overlay)

        # Wallpaper
        wp = "/usr/share/wallpapers/bloom/bloom-wallpaper.png"
        if os.path.exists(wp):
            pic = Gtk.Picture.new_for_filename(wp)
            pic.set_content_fit(Gtk.ContentFit.COVER)
            pic.set_can_shrink(True)
            pic.set_hexpand(True)
            pic.set_vexpand(True)
            overlay.set_child(pic)
        else:
            bg = Gtk.Box(); bg.set_hexpand(True); bg.set_vexpand(True)
            overlay.set_child(bg)

        # Dark tint
        tint = Gtk.Box()
        tint.add_css_class("tint")
        tint.set_hexpand(True); tint.set_vexpand(True)
        overlay.add_overlay(tint)
        overlay.set_overlay_pass_through(tint, True)

        # Login card (centered)
        card_wrap = Gtk.Box()
        card_wrap.set_halign(Gtk.Align.CENTER)
        card_wrap.set_valign(Gtk.Align.CENTER)
        overlay.add_overlay(card_wrap)
        self._build_card(card_wrap)

        # Power row (bottom center)
        power_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        power_row.set_halign(Gtk.Align.CENTER)
        power_row.set_valign(Gtk.Align.END)
        power_row.set_margin_bottom(32)
        overlay.add_overlay(power_row)
        for icon, label, cmd in [
            ("󰒲", "Suspend",  ["systemctl", "suspend"]),
            ("󰑙", "Reboot",   ["systemctl", "reboot"]),
            ("󰐥", "Shutdown", ["systemctl", "poweroff"]),
        ]:
            btn = Gtk.Button(label=f"{icon}  {label}")
            btn.add_css_class("power-btn")
            btn.connect("clicked", lambda _, c=cmd: subprocess.Popen(c))
            power_row.append(btn)

        GLib.timeout_add_seconds(1, self._tick)
        self._tick()
        win.present()

    def _build_card(self, parent):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        card.add_css_class("card")
        parent.append(card)

        # Logo
        logo = Gtk.Label(label="❀  BLOOM")
        logo.add_css_class("logo")
        logo.set_halign(Gtk.Align.CENTER)
        card.append(logo)

        # Clock
        self._clock_lbl = Gtk.Label()
        self._clock_lbl.add_css_class("clock")
        self._clock_lbl.set_halign(Gtk.Align.CENTER)
        card.append(self._clock_lbl)

        # Date
        self._date_lbl = Gtk.Label()
        self._date_lbl.add_css_class("dateline")
        self._date_lbl.set_halign(Gtk.Align.CENTER)
        card.append(self._date_lbl)

        # User selector
        users = get_users()
        if len(users) > 1:
            lbl = Gtk.Label(label="USER"); lbl.add_css_class("field-lbl")
            lbl.set_halign(Gtk.Align.START); card.append(lbl)
            model = Gtk.StringList.new(users)
            self._user_dd = Gtk.DropDown(model=model)
            self._user_dd.set_hexpand(True)
            card.append(self._user_dd)
            self._username = users[0]
            self._user_dd.connect("notify::selected",
                lambda dd, _: setattr(self, "_username", users[dd.get_selected()]))
        else:
            self._username = users[0]

        # Password
        lbl = Gtk.Label(label="PASSWORD"); lbl.add_css_class("field-lbl")
        lbl.set_halign(Gtk.Align.START); card.append(lbl)
        self._pw = Gtk.PasswordEntry()
        self._pw.set_hexpand(True)
        self._pw.set_show_peek_icon(True)
        self._pw.connect("activate", lambda _: self._do_login())
        card.append(self._pw)

        # Session selector
        sessions = get_sessions()
        self._session_cmds = [cmd for _, cmd in sessions]
        lbl = Gtk.Label(label="SESSION"); lbl.add_css_class("field-lbl")
        lbl.set_halign(Gtk.Align.START); card.append(lbl)
        model = Gtk.StringList.new([n for n, _ in sessions])
        self._session_dd = Gtk.DropDown(model=model)
        self._session_dd.set_hexpand(True)
        card.append(self._session_dd)

        # Error
        self._err_lbl = Gtk.Label(label="")
        self._err_lbl.add_css_class("error")
        self._err_lbl.set_halign(Gtk.Align.CENTER)
        self._err_lbl.set_visible(False)
        card.append(self._err_lbl)

        # Login button
        self._login_btn = Gtk.Button(label="  Sign In")
        self._login_btn.add_css_class("login-btn")
        self._login_btn.connect("clicked", lambda _: self._do_login())
        card.append(self._login_btn)

    def _tick(self):
        now = time.localtime()
        self._clock_lbl.set_text(time.strftime("%H:%M", now))
        self._date_lbl.set_text(time.strftime("%A, %B %-d", now))
        return True

    def _do_login(self):
        self._login_btn.set_sensitive(False)
        self._err_lbl.set_visible(False)
        pw   = self._pw.get_text()
        user = self._username
        idx  = self._session_dd.get_selected()
        cmd  = (self._session_cmds[idx]
                if idx < len(self._session_cmds)
                else "uwsm start hyprland.desktop").split()

        def auth():
            try:
                resp = greetd({"type": "create_session", "username": user})
                # Handle any prompt (usually asking for password)
                while resp.get("type") == "auth_message":
                    resp = greetd({"type": "post_auth_message_response",
                                   "response": pw})
                if resp.get("type") == "success":
                    greetd({"type": "start_session", "cmd": cmd, "env": []})
                    GLib.idle_add(self.quit)
                else:
                    err = resp.get("description", "Authentication failed")
                    try:
                        greetd({"type": "cancel_session"})
                    except Exception:
                        pass
                    GLib.idle_add(self._show_error, err)
            except Exception as e:
                GLib.idle_add(self._show_error, str(e))

        threading.Thread(target=auth, daemon=True).start()

    def _show_error(self, msg):
        self._err_lbl.set_text(f"  {msg}")
        self._err_lbl.set_visible(True)
        self._pw.set_text("")
        self._pw.grab_focus()
        self._login_btn.set_sensitive(True)
        return False


if __name__ == "__main__":
    _greetd_connect()
    BloomGreeter().run([])
